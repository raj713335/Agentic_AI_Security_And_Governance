# Agentic AI Security and Governance Environment Variables

# OpenAI API Key for the LangChain integration (Required for live LLM planning)
OPENAI_API_KEY="your-openai-api-key-here"

# The OpenAI model to use (Optional, defaults to gpt-4o)
OPENAI_MODEL_NAME="gpt-4o"

# Comma-separated list of disabled tools for the kill switch (Optional)
# Example: DISABLED_TOOLS="delete_record,wire_funds"
DISABLED_TOOLS=""
